{
  "name": "@18ways/react",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/bundle.cjs.js",
  "module": "dist/bundle.esm.js",
  "types": "./index.tsx",
  "exports": {
    ".": {
      "types": "./index.tsx",
      "import": "./index.tsx",
      "require": "./dist/bundle.cjs.js"
    },
    "./testing": {
      "types": "./testing.ts",
      "import": "./testing.ts"
    }
  },
  "files": [
    "dist",
    "*.ts",
    "*.tsx",
    "global.d.ts"
  ],
  "scripts": {
    "build": "bun run bun-build.ts",
    "dev": "bun run --watch bun-build.ts",
    "ts:check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "e2e": "bun run e2e/run-react-e2e.tsx"
  },
  "dependencies": {
    "@18ways/core": "*",
    "fast-xml-parser": "^4.4.1"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^14.3.1",
    "@types/bun": "latest",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.1",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "description": "React runtime for 18ways",
  "packageManager": "bun@1.3.8"
}
